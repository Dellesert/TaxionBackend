# ==============================================
# SMTP Configuration for 2FA
# ==============================================

# UniSender (Recommended - 14,000 emails/month free, Russian service)
# SMTP_HOST=smtp.unisender.com
# SMTP_PORT=587
# SMTP_USER=your_unisender_api_key
# SMTP_PASSWORD=your_unisender_api_secret
# SMTP_FROM_EMAIL=noreply@yourdomain.com
# SMTP_FROM_NAME=Tachyon Messenger

# Yandex Mail (Free - ~500 emails/day, requires domain)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.ru
SMTP_PASSWORD=your_yandex_app_password
SMTP_FROM_EMAIL=noreply@yourdomain.ru
SMTP_FROM_NAME=Tachyon Messenger

# Gmail (if using Gmail for testing)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM_EMAIL=your_email@gmail.com
# SMTP_FROM_NAME=Tachyon Messenger

# For local testing with MailHog
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USER=test
# SMTP_PASSWORD=test
# SMTP_FROM_EMAIL=noreply@localhost
# SMTP_FROM_NAME=Tachyon Messenger (Dev)
