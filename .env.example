# ==============================================
# Tachyon Messenger Environment Configuration
# Скопируйте этот файл в .env и настройте под свою среду
# ==============================================

# Environment Settings
ENVIRONMENT=development
GIN_MODE=debug
LOG_LEVEL=info
LOG_FORMAT=json

# ==============================================
# Database Configuration (PostgreSQL)
# ==============================================
POSTGRES_DB=tachyon_messenger
POSTGRES_USER=tachyon_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5432

DATABASE_URL=postgres://tachyon_user:your_secure_password_here@postgres:5432/tachyon_messenger?sslmode=disable

# ==============================================
# Redis Configuration
# ==============================================
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379

REDIS_URL=redis://:your_redis_password_here@redis:6379

# ==============================================
# Authentication Configuration
# ==============================================
AUTH_MODE=session

# Длительность сессии в часах
# 0.5 = 30 минут (рекомендуется для супер-админов)
# 24 = 1 день (для обычных пользователей)
SESSION_DURATION_HOURS=0.5

# ==============================================
# WebAuthn / Passkey Configuration
# ==============================================
# Relying Party ID (обычно домен без протокола)
WEBAUTHN_RP_ID=localhost

# Отображаемое имя сервиса
WEBAUTHN_RP_DISPLAY_NAME=Tachyon Messenger

# Origin (протокол + домен + порт для разработки)
WEBAUTHN_RP_ORIGIN=http://localhost:8080

# ==============================================
# Service Ports
# ==============================================
GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
CHAT_SERVICE_PORT=8082
TASK_SERVICE_PORT=8083
CALENDAR_SERVICE_PORT=8084
POLL_SERVICE_PORT=8085
NOTIFICATION_SERVICE_PORT=8087
SERVER_PORT=8081

# ==============================================
# Poll Service Configuration
# ==============================================
# Интервал проверки истекших опросов (в минутах)
# Рекомендуемые значения:
# - 2-5 минут для малых систем (< 1000 опросов)
# - 5-10 минут для средних систем (1000-10000 опросов)
# - 10-30 минут для больших систем (> 10000 опросов)
# По умолчанию: 5 минут
POLL_AUTO_CLOSE_INTERVAL_MINUTES=5

# ==============================================
# Service URLs (для Docker среды)
# ==============================================
USER_SERVICE_URL=http://user-service:8081
CHAT_SERVICE_URL=http://chat-service:8082
TASK_SERVICE_URL=http://task-service:8083
CALENDAR_SERVICE_URL=http://calendar-service:8084
POLL_SERVICE_URL=http://poll-service:8085
NOTIFICATION_SERVICE_URL=http://notification-service:8087

# Backend URL (для генерации ссылок в email)
# Для локальной разработки: http://localhost:8080 (gateway)
# Для production: https://yourdomain.com
BACKEND_URL=http://localhost:8080

# ==============================================
# Development Settings
# ==============================================
DEBUG=true
ENABLE_CORS=true
# CORS разрешенные источники (включая порты для Vite dev server)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8093,http://localhost:5173,http://localhost:5174,http://localhost:5175

ENABLE_REQUEST_LOGGING=true
ENABLE_SQL_LOGGING=true

# ==============================================
# Super Admin Initialization
# ВАЖНО: Измените эти значения после первого запуска!
# ==============================================
SUPER_ADMIN_EMAIL=superadmin@taxion.local
SUPER_ADMIN_PASSWORD=ChangeMe123!@#SuperSecure
SUPER_ADMIN_NAME=Super Administrator

# ==============================================
# Frontend Configuration (for invitation links)
# ==============================================
FRONTEND_URL=http://localhost:3000

# App Store URLs (для ссылок в письмах-приглашениях)
APP_STORE_URL=https://apps.apple.com/app/tachyon-messenger
GOOGLE_PLAY_URL=https://play.google.com/store/apps/details?id=com.tachyon.messenger
# Windows App URL (если пусто, будет использоваться BACKEND_URL/downloads/windows/latest)
WINDOWS_APP_URL=

# ==============================================
# Performance Settings
# ==============================================

# PostgreSQL Connection Pool Configuration
# Максимальное количество открытых соединений с БД
# Рекомендуется: 20-50 для небольших приложений, 50-100 для средних
DB_MAX_OPEN_CONNS=25

# Минимальное количество неактивных соединений в пуле
# Рекомендуется: 5-10% от MAX_OPEN_CONNS
DB_MAX_IDLE_CONNS=5

# Максимальное время жизни соединения (duration format: 1h, 30m, 3600s)
# После этого времени соединение будет закрыто и создано новое
# Рекомендуется: 1h для production, можно увеличить до 4h
DB_CONN_MAX_LIFETIME=1h

# Максимальное время простоя соединения (duration format: 10m, 600s)
# Неактивные соединения будут закрыты после этого времени
# Рекомендуется: 10m-30m
DB_CONN_MAX_IDLE_TIME=10m

# Уровень логирования GORM (silent, error, warn, info)
# silent - без логов, error - только ошибки, warn - предупреждения, info - все запросы
DB_LOG_LEVEL=info

REDIS_MAX_IDLE=10
REDIS_MAX_ACTIVE=100

# ==============================================
# File Storage
# ==============================================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# Путь для хранения файлов приложений (Windows/Android)
# По умолчанию: ./storage/app-versions
APP_STORAGE_PATH=./storage/app-versions

# ==============================================
# Email Configuration (для Notification Service)
# ==============================================
EMAIL_MODE=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Tachyon Messenger
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=30
SMTP_MAX_RETRIES=3
SMTP_RETRY_DELAY_SECONDS=5
SMTP_POOL_SIZE=10
SMTP_RATE_LIMIT_RPS=5

# ==============================================
# Notification Settings
# ==============================================
NOTIFICATION_CONCURRENT_WORKERS=5
NOTIFICATION_QUEUE_SIZE=1000
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY=60

# ==============================================
# Firebase Cloud Messaging (FCM) Push Notifications
# ==============================================
# Enable/disable FCM push notifications
FCM_ENABLED=false

# Path to Firebase service account credentials JSON file
# Получить в Firebase Console -> Project Settings -> Service Accounts -> Generate New Private Key
FCM_CREDENTIALS_FILE=/path/to/firebase-credentials.json

# Firebase project ID (из Firebase Console)
FCM_PROJECT_ID=your-project-id

