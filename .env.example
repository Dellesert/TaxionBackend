# ==============================================
# Tachyon Messenger Environment Configuration
# Скопируйте этот файл в .env и настройте под свою среду
# ==============================================

# Environment Settings
ENVIRONMENT=development
GIN_MODE=debug
LOG_LEVEL=info
LOG_FORMAT=json

# ==============================================
# Database Configuration (PostgreSQL)
# ==============================================
POSTGRES_DB=tachyon_messenger
POSTGRES_USER=tachyon_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5432

DATABASE_URL=postgres://tachyon_user:your_secure_password_here@postgres:5432/tachyon_messenger?sslmode=disable

# ==============================================
# Redis Configuration
# ==============================================
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379

REDIS_URL=redis://:your_redis_password_here@redis:6379

# ==============================================
# Authentication Configuration
# ==============================================
AUTH_MODE=session

# Длительность сессии в часах
# 0.5 = 30 минут (рекомендуется для супер-админов)
# 24 = 1 день (для обычных пользователей)
SESSION_DURATION_HOURS=0.5

# ==============================================
# WebAuthn / Passkey Configuration
# ==============================================
# Relying Party ID (обычно домен без протокола)
WEBAUTHN_RP_ID=localhost

# Отображаемое имя сервиса
WEBAUTHN_RP_DISPLAY_NAME=Tachyon Messenger

# Origin (протокол + домен + порт для разработки)
WEBAUTHN_RP_ORIGIN=http://localhost:8080

# ==============================================
# Service Ports
# ==============================================
GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
CHAT_SERVICE_PORT=8082
TASK_SERVICE_PORT=8083
CALENDAR_SERVICE_PORT=8084
POLL_SERVICE_PORT=8085
NOTIFICATION_SERVICE_PORT=8087
SERVER_PORT=8081

# ==============================================
# Service URLs (для Docker среды)
# ==============================================
USER_SERVICE_URL=http://user-service:8081
CHAT_SERVICE_URL=http://chat-service:8082
TASK_SERVICE_URL=http://task-service:8083
CALENDAR_SERVICE_URL=http://calendar-service:8084
POLL_SERVICE_URL=http://poll-service:8085
NOTIFICATION_SERVICE_URL=http://notification-service:8087

# ==============================================
# Development Settings
# ==============================================
DEBUG=true
ENABLE_CORS=true
# CORS разрешенные источники (включая порты для Vite dev server)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8093,http://localhost:5173,http://localhost:5174,http://localhost:5175

ENABLE_REQUEST_LOGGING=true
ENABLE_SQL_LOGGING=true

# ==============================================
# Super Admin Initialization
# ВАЖНО: Измените эти значения после первого запуска!
# ==============================================
SUPER_ADMIN_EMAIL=superadmin@taxion.local
SUPER_ADMIN_PASSWORD=ChangeMe123!@#SuperSecure
SUPER_ADMIN_NAME=Super Administrator

# ==============================================
# Performance Settings
# ==============================================
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=3600

REDIS_MAX_IDLE=10
REDIS_MAX_ACTIVE=100

# ==============================================
# File Storage
# ==============================================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# ==============================================
# Email Configuration (для Notification Service)
# ==============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Tachyon Messenger
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=30
SMTP_MAX_RETRIES=3
SMTP_RETRY_DELAY_SECONDS=5
SMTP_POOL_SIZE=10
SMTP_RATE_LIMIT_RPS=5

# ==============================================
# Notification Settings
# ==============================================
NOTIFICATION_CONCURRENT_WORKERS=5
NOTIFICATION_QUEUE_SIZE=1000
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY=60

