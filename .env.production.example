# ==============================================
# Tachyon Messenger - Production Environment Template
# ==============================================
# ВАЖНО: Скопируйте этот файл в .env.production.local и настройте
# команда: cp .env.production.example .env.production.local
# ==============================================

# Environment Settings
ENVIRONMENT=production
GIN_MODE=release
LOG_LEVEL=info
LOG_FORMAT=json

# ==============================================
# Database Configuration (PostgreSQL)
# ВАЖНО: Используйте СИЛЬНЫЕ пароли в продакшене!
# Генерация: openssl rand -base64 32
# ==============================================
POSTGRES_DB=tachyon_messenger
POSTGRES_USER=tachyon_user
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD_32_CHARS
POSTGRES_PORT=5432

# Для продакшена ОБЯЗАТЕЛЬНО используйте SSL: sslmode=require
DATABASE_URL=postgres://tachyon_user:CHANGE_ME_GENERATE_STRONG_PASSWORD_32_CHARS@postgres:5432/tachyon_messenger?sslmode=require

# ==============================================
# Redis Configuration
# ВАЖНО: Используйте СИЛЬНЫЙ пароль!
# Генерация: openssl rand -base64 32
# ==============================================
REDIS_PASSWORD=CHANGE_ME_GENERATE_STRONG_REDIS_PASSWORD_32_CHARS
REDIS_PORT=6379

REDIS_URL=redis://:CHANGE_ME_GENERATE_STRONG_REDIS_PASSWORD_32_CHARS@redis:6379

# ==============================================
# Authentication Configuration
# ==============================================
# Production: используйте session для большей безопасности
AUTH_MODE=session

# Session Duration: 0.5 часа (30 минут) для production безопасности
# Увеличьте если нужно, но не рекомендуется больше 2 часов
SESSION_DURATION_HOURS=0.5

# ==============================================
# WebAuthn / Passkey Configuration
# ==============================================
# ВАЖНО: НЕ указывайте WEBAUTHN_RP_ID - он вычисляется автоматически из Origin!
# RP ID автоматически извлекается из hostname каждого origin.
# Это позволяет поддерживать несколько доменов (например, app и admin panel).

# Отображаемое имя сервиса
WEBAUTHN_RP_DISPLAY_NAME=Tachyon Messenger

# Production origins (HTTPS ОБЯЗАТЕЛЕН!)
# Через запятую для нескольких доменов (основное приложение + админ-панель)
# Каждый origin автоматически получает свой RP ID из hostname
# Пример для одного домена: https://yourdomain.com
# Пример для нескольких: https://app.yourdomain.com,https://admin.yourdomain.com
WEBAUTHN_RP_ORIGIN=https://yourdomain.com

# ==============================================
# Service Ports (внутренние Docker порты)
# Не меняйте без необходимости
# ==============================================
GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
CHAT_SERVICE_PORT=8082
TASK_SERVICE_PORT=8083
CALENDAR_SERVICE_PORT=8084
POLL_SERVICE_PORT=8085
NOTIFICATION_SERVICE_PORT=8087
FILE_SERVICE_PORT=8088
SERVER_PORT=8081

# ==============================================
# Service URLs (внутренние Docker URL)
# Не меняйте - это имена контейнеров в Docker
# ==============================================
USER_SERVICE_URL=http://user-service:8081
CHAT_SERVICE_URL=http://chat-service:8082
TASK_SERVICE_URL=http://task-service:8083
CALENDAR_SERVICE_URL=http://calendar-service:8084
POLL_SERVICE_URL=http://poll-service:8085
NOTIFICATION_SERVICE_URL=http://notification-service:8087
FILE_SERVICE_URL=http://file-service:8088

# Backend URL (для генерации ссылок в email)
# ВАЖНО: Укажите ваш ПУБЛИЧНЫЙ домен!
# Примеры:
# - https://yourdomain.com
# - https://api.yourdomain.com
# Не используйте внутренние Docker URL!
BACKEND_URL=https://yourdomain.com

# ==============================================
# Production Settings
# ==============================================
DEBUG=false
ENABLE_CORS=true

# Production CORS: ТОЛЬКО ваши production домены!
# Разделяйте запятой без пробелов
# Пример: https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=https://yourdomain.com

# Логирование в production
ENABLE_REQUEST_LOGGING=true
ENABLE_SQL_LOGGING=false

# ==============================================
# Security Settings - Production
# ==============================================
# JWT tokens (если используете JWT mode в будущем)
JWT_ACCESS_TOKEN_EXPIRE=15
JWT_REFRESH_TOKEN_EXPIRE=1440
SESSION_TIMEOUT=30

# ==============================================
# Super Admin Initialization
# КРИТИЧЕСКИ ВАЖНО: Сразу измените после первого запуска!
# ==============================================
# Email вашего главного администратора
SUPER_ADMIN_EMAIL=admin@yourdomain.com

# ВАЖНО: Используйте сильный пароль и ОБЯЗАТЕЛЬНО измените его после первого входа!
SUPER_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD_MIN_16_CHARS

# Имя администратора
SUPER_ADMIN_NAME=System Administrator

# ==============================================
# Frontend Configuration
# ==============================================
# Production frontend URL
# Пример: https://yourdomain.com или https://app.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# Deep link для мобильного приложения (если есть)
MOBILE_DEEP_LINK=tachyon://

# App Store URLs (для ссылок в письмах-приглашениях)
APP_STORE_URL=https://apps.apple.com/app/tachyon-messenger
GOOGLE_PLAY_URL=https://play.google.com/store/apps/details?id=com.tachyon.messenger
# Windows App URL (если пусто, будет использоваться BACKEND_URL/downloads/windows/latest)
# Можете указать прямую ссылку на GitHub Releases или свой CDN
WINDOWS_APP_URL=

# ==============================================
# Performance Settings - Production
# ==============================================
# Увеличенные значения для production нагрузки
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=3600

REDIS_MAX_IDLE=20
REDIS_MAX_ACTIVE=200

# ==============================================
# File Storage - Production
# ==============================================
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE=10485760

# Путь для хранения файлов приложений (Windows/Android)
# Для production рекомендуется использовать постоянное хранилище (volume)
APP_STORAGE_PATH=/app/storage/app-versions

# Production base URL (для ссылок на файлы)
# Должен совпадать с FRONTEND_URL или вашим API URL
BASE_URL=https://yourdomain.com

# ==============================================
# Email Configuration - Production
# ==============================================
EMAIL_MODE=smtp

# SMTP настройки (пример для Gmail)
# Для Gmail используйте App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Tachyon Messenger
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password-here

# Альтернатива: для SendGrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key

# ==============================================
# Notification Settings - Production
# ==============================================
# Увеличенные значения для production
NOTIFICATION_CONCURRENT_WORKERS=10
NOTIFICATION_QUEUE_SIZE=2000
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY=60

# ==============================================
# Firebase Cloud Messaging (FCM) Push Notifications
# ==============================================
# Enable/disable FCM push notifications
FCM_ENABLED=true

# Path to Firebase service account credentials JSON file
# В production обычно монтируется через Docker volume или secrets
FCM_CREDENTIALS_FILE=/app/credentials/firebase-credentials.json

# Firebase project ID (из Firebase Console)
FCM_PROJECT_ID=your-production-project-id

# ==============================================
# Monitoring & Health Checks
# ==============================================
HEALTH_CHECK_INTERVAL=30
METRICS_ENABLED=true

# ==============================================
# Rate Limiting (рекомендуется для production)
# ==============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=20

# ==============================================
# Backup Configuration
# ==============================================
# Автоматические бэкапы (требует настройки cron)
BACKUP_ENABLED=true
BACKUP_INTERVAL=24h
BACKUP_RETENTION_DAYS=30

# ==============================================
# Security Headers (для gateway)
# ==============================================
SECURITY_HEADERS_ENABLED=true
HSTS_ENABLED=true
HSTS_MAX_AGE=31536000
