# ==============================================
# Authentication Configuration
# ==============================================

# Authentication Mode
# Options: "jwt" (stateless) or "session" (stateful)
# Default: jwt
AUTH_MODE=jwt

# Session Duration (for session mode)
# Duration in hours for session expiration
# Default: 168 hours (7 days)
SESSION_DURATION_HOURS=168

# JWT Configuration (for jwt mode)
JWT_SECRET=your-secret-key-here-change-in-production

# ==============================================
# Switching Authentication Modes
# ==============================================
#
# You can switch between modes in two ways:
#
# 1. Environment Variable (requires service restart):
#    - Update AUTH_MODE in .env
#    - Restart user-service: docker-compose restart user-service
#
# 2. Admin API (dynamic, no restart needed):
#    PUT /api/v1/admin/settings/auth/mode
#    {
#      "auth_mode": "session"  // or "jwt"
#    }
#
# ==============================================
# Notes
# ==============================================
#
# JWT Mode (Stateless):
# - No Redis dependency for auth
# - Tokens cannot be revoked
# - Logout is client-side only
# - Good for: Scalability, offline operation
#
# Session Mode (Stateful):
# - Requires Redis
# - Sessions can be revoked instantly
# - Server-side logout
# - Good for: Security, user session management
#
